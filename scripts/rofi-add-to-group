#!/bin/sh
# Add a workspace to the current group (chosen via rofi).
# Shows all workspaces with their group memberships.
# Typing a new name creates the workspace in the current group.

SWAYG="$HOME/.cargo/bin/swayg"

current_output=$(swaymsg -t get_workspaces 2>/dev/null | python3 -c "
import json, sys
for w in json.load(sys.stdin):
    if w['focused']:
        print(w['output'])
        break
")

current_group=$($SWAYG group active "$current_output" 2>/dev/null | tail -1)

workspaces=$($SWAYG workspace list --plain --groups 2>/dev/null)

choice=$(printf '%s\n' "$workspaces" | rofi -dmenu -p "Add workspace (+name):")
if [ -z "$choice" ]; then
    exit 0
fi

target_ws="${choice%%│*}"
target_ws="${target_ws#+}"
$SWAYG workspace add "$target_ws"
