#!/bin/sh
# Toggle the current workspace as global (visible in all groups).

current_ws=$(swaymsg -t get_workspaces 2>/dev/null | python3 -c "
import json, sys
for w in json.load(sys.stdin):
    if w['focused']:
        print(w['name'])
        break
")

if [ -z "$current_ws" ]; then
    notify-send "swayg" "Cannot determine current workspace."
    exit 1
fi

is_global=$(sqlite3 ~/.local/share/swayg/swayg.db "SELECT is_global FROM workspaces WHERE name = '$current_ws';" 2>/dev/null)

if [ "$is_global" = "1" ]; then
    $HOME/.cargo/bin/swayg workspace unglobal "$current_ws"
    notify-send "swayg" "Workspace '$current_ws' is no longer global."
else
    $HOME/.cargo/bin/swayg workspace global "$current_ws"
    notify-send "swayg" "Workspace '$current_ws' is now global."
fi
