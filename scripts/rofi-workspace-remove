#!/bin/sh
# Remove the current workspace from a group (chosen via rofi).
# Shows only groups the workspace is currently in.

current_ws=$(swaymsg -t get_workspaces 2>/dev/null | python3 -c "
import json, sys
for w in json.load(sys.stdin):
    if w['focused']:
        n = w['name']
        for s in ('_class_hidden', '_class_global'):
            n = n.removesuffix(s)
        print(n)
        break
")

if [ -z "$current_ws" ]; then
    notify-send "swayg" "Cannot determine current workspace."
    exit 1
fi

groups=$(swayg workspace groups "$current_ws" | sed 's/.*: //; s/"//g; s/, */\n/g')

if [ -z "$groups" ]; then
    notify-send "swayg" "Workspace '$current_ws' is not in any group."
    exit 0
fi

group=$(echo "$groups" | rofi -dmenu -p "Remove '$current_ws' from group:")
if [ -z "$group" ]; then
    notify-send "swayg" "Remove from group cancelled."
    exit 0
fi

swayg workspace remove "$current_ws" --group "$group"
