#!/bin/sh
# Navigate to a workspace in the current active group on the current output.

output=$(swaymsg -t get_workspaces 2>/dev/null | python3 -c "
import json, sys
for w in json.load(sys.stdin):
    if w['focused']:
        print(w['output'])
        break
")

if [ -z "$output" ]; then
    notify-send "swayg" "Cannot determine current output."
    exit 1
fi

current_ws=$(swaymsg -t get_workspaces 2>/dev/null | python3 -c "
import json, sys
for w in json.load(sys.stdin):
    if w['focused']:
        print(w['name'])
        break
")

workspace=$($HOME/.cargo/bin/swayg workspace list --output "$output" | awk '/^  /{print $1}' | rofi -dmenu -p "Go to workspace (+name):" -a "$current_ws")
if [ -z "$workspace" ]; then
    notify-send "swayg" "Navigation cancelled."
    exit 0
fi

workspace="${workspace#+}"

$HOME/.cargo/bin/swayg nav go "$workspace"
