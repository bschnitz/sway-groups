#!/bin/sh
# Switch to a workspace via rofi.
# Shows all workspaces with their group (one line per workspace+group).
# Typing a new name creates the workspace in the current group.
# Output is auto-resolved via group state when switching.

current_output=$(swaymsg -t get_workspaces 2>/dev/null | python3 -c "
import json, sys
for w in json.load(sys.stdin):
    if w['focused']:
        print(w['output'])
        break
")

active_group=$($HOME/.cargo/bin/swayg group active "$current_output" 2>/dev/null)

choice=$($HOME/.cargo/bin/swayg workspace list --plain --groups --flatten 2>/dev/null | rofi -dmenu -p "Switch to (+name):" -a "$active_group")
if [ -z "$choice" ]; then
    exit 0
fi

workspace="${choice%%│*}"
workspace="${workspace#+}"
$HOME/.cargo/bin/swayg nav go "$workspace"
